        "/employee/store": {
            "post": {
                "tags": [
                    "Funcionários"
                ],
                "summary": "Cadastra um novo funcionário completo",
                "description": "Cria User (Role 2), Employee e Address em uma transação única.",
                "operationId": "c81489ea4475afcd4ca5aea00e9f24af",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "cpf",
                                    "idOccupation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "joao@farmacia.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "idOccupation": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "cpf": {
                                        "type": "string",
                                        "example": "000.000.000-00"
                                    },
                                    "zip_code": {
                                        "type": "string",
                                        "example": "41000-000"
                                    },
                                    "street": {
                                        "type": "string",
                                        "example": "Rua Exemplo"
                                    },
                                    "number": {
                                        "type": "string",
                                        "example": "123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Criado com sucesso"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
