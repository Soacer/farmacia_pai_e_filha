{
    "openapi": "3.0.0",
    "info": {
        "title": "Farmácia Pai e Filha API",
        "description": "API para gerenciamento da Farmácia Pai e Filha",
        "version": "1.0.0"
    },
    "paths": {
        "/": {
            "servers": [
                {
                    "url": "http://localhost:8000",
                    "description": "Servidor Local"
                }
            ]
        },
        "/login/auth": {
            "get": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Exibe o formulário de login",
                "operationId": "6eb587d0dcfdcb28c0e0b772f28a1737",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            },
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Realiza a autenticação",
                "operationId": "e5ac035140b836a2d55659ee0d58df0d",
                "responses": {
                    "302": {
                        "description": "Redirecionamento"
                    }
                }
            }
        },
        "/user/dashboard": {
            "get": {
                "tags": [
                    "Painel"
                ],
                "summary": "Exibe o Dashboard",
                "operationId": "ad585d7d693d6694b71c6084a6277f53",
                "responses": {
                    "200": {
                        "description": "Dados do Dashboard carregados",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Customer": {
                "title": "Cliente/Funcionário",
                "description": "Estrutura de dados para cadastro de pessoas",
                "properties": {
                    "idCustomers": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Maria Souza"
                    },
                    "cpf": {
                        "type": "string",
                        "example": "000.000.000-00"
                    },
                    "phone": {
                        "type": "string",
                        "example": "71999998888"
                    },
                    "email": {
                        "type": "string",
                        "example": "maria@farmacia.com"
                    },
                    "address": {
                        "type": "string",
                        "example": "Rua Principal, 123"
                    }
                },
                "type": "object"
            },
            "Role": {
                "title": "Permissão",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "roles": {
                        "type": "string",
                        "example": "employee"
                    }
                },
                "type": "object"
            },
            "User": {
                "title": "Usuário",
                "description": "Modelo de usuário para autenticação",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Administrador"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@admin.com"
                    },
                    "idRoles": {
                        "description": "ID do cargo",
                        "type": "integer",
                        "example": 1
                    },
                    "isActive": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Autenticação",
            "description": "Endpoints de acesso"
        },
        {
            "name": "Painel",
            "description": "Painel"
        }
    ]
}