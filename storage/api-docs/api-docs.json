        "/create-product": {
            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Cria um produto e opcionalmente fornecedor/lote",
                "description": "Registra o produto e, se solicitado, cria o fornecedor com endereço e o primeiro lote.",
                "operationId": "450a0d405226a5c2a1305695ed1bb3b4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "idCategory",
                                    "name",
                                    "price",
                                    "barcode"
                                ],
                                "properties": {
                                    "idCategory": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Dipirona 500mg"
                                    },
                                    "barcode": {
                                        "type": "string",
                                        "example": "7891234567890"
                                    },
                                    "price": {
                                        "type": "string",
                                        "example": "15,50"
                                    },
                                    "min_stock_alert": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "novoFornecedor": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "cnpj": {
                                        "type": "string",
                                        "example": "12345678000199"
                                    },
                                    "zip_code": {
                                        "type": "string",
                                        "example": "41000000"
                                    },
                                    "street": {
                                        "type": "string",
                                        "example": "Avenida Sete de Setembro"
                                    },
                                    "number": {
                                        "type": "string",
                                        "example": "100"
                                    },
                                    "neighborhood": {
                                        "type": "string",
                                        "example": "Centro"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Salvador"
                                    },
                                    "state": {
                                        "type": "string",
                                        "example": "BA"
                                    },
                                    "batch_code": {
                                        "type": "string",
                                        "example": "LOT-2026-X"
                                    },
                                    "quantity": {
                                        "type": "integer",
                                        "example": 100
                                    },
                                    "expiration_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2028-12-31"
                                    },
                                    "cost_price": {
                                        "type": "string",
                                        "example": "5,50"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sucesso"
                    },
                    "500": {
                        "description": "Erro Interno"
                    }
                }
            }
        },
        "/product/update/{id}": {
            "put": {
                "tags": [
                    "Products"
                ],
                "summary": "Atualiza produto e lote simultaneamente",
                "operationId": "9b072fa387b78c4661dbe7a637bdbac4",
