        "/employees/{id}": {
            "put": {
                "tags": [
                    "Funcionários"
                ],
                "summary": "Atualiza os dados de um funcionário",
                "operationId": "b3a9ade2ed93de1c1069d0529fee56b0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID (UUID) do funcionário",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "idOccupation": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "cpf": {
                                        "type": "string",
                                        "example": "123.456.789-01"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "71988887777"
                                    },
                                    "salary": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 2500.5
                                    },
                                    "isActive": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "hire_date": {
                                        "type": "string",
                                        "format": "date"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Atualizado com sucesso"
                    },
                    "404": {
                        "description": "Funcionário não encontrado"
                    }
                }
            }
        },
