{
    "openapi": "3.0.0",
    "info": {
        "title": "Farmácia Pai e Filha API",
        "description": "API para gerenciamento da Farmácia Pai e Filha",
        "version": "1.0.0"
    },
    "paths": {
        "/": {
            "servers": [
                {
                    "url": "http://localhost:8000",
                    "description": "Servidor Local"
                }
            ]
        },
        "/users/create-user": {
            "post": {
                "tags": [
                    "users"
                ],
                "summary": "Cadastrar novo usuário",
                "operationId": "5e62d710ed0852486485461d72017cc6",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Nome do usuário",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Email do usuário",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "email"
                        }
                    },
                    {
                        "name": "password",
                        "in": "query",
                        "description": "Senha do usuário",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "password"
                        }
                    },
                    {
                        "name": "idRoles",
                        "in": "query",
                        "description": "Role do usuário",
                        "required": true,
                        "schema": {
                            "type": "foreignId",
                            "format": "number"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Usuário criado com sucesso"
                    },
                    "422": {
                        "description": "Dados inválidos"
                    }
                }
            }
        }
    },
    "tags": [
